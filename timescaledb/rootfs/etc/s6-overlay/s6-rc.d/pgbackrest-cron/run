#!/command/with-contenv bashio
# pgbackrest-cron: s6 longrun service that runs the daily pgBackRest backup schedule.
# Wakes at 02:00 UTC daily, dispatches full/diff/incr to repo1 per calendar (BKUP-06),
# and annual full to repo2 on Jan 1 (D-06). Retry logic per BKUP-07 / D-03.
# Sources backup-lib.sh for supervisor API helpers (D-01).
#
# WHY set -uo pipefail and NOT -e: the outer while-true loop must continue after any
# individual backup failure. With -e the first failed pgbackrest call would abort the
# entire script, leaving the container without further backup attempts until restart.
# D-05 / T-09-06: backup failures must never propagate to the postgres longrun.
set -uo pipefail

PGDATA="/data/postgres"
SECRETS_DIR="/data/secrets"

# shellcheck source=rootfs/usr/lib/timescaledb/backup-lib.sh
. /usr/lib/timescaledb/backup-lib.sh

# Idle permanently when backup is disabled. The s6 service is always started (it is
# registered in user/contents.d), but it must not attempt any pgbackrest calls when
# backup_enabled=false.
#
# WHY while-loop and not 'exec sleep infinity': Alpine BusyBox sleep does not accept
# 'infinity' as an argument — it exits immediately with an error, causing s6 to
# restart-loop the service. A while-true sleep 86400 loop stays alive indefinitely
# on all BusyBox versions.
if ! bashio::config.true 'backup_enabled'; then
    bashio::log.info "pgbackrest-cron: backup_enabled=false — service idle"
    while true; do sleep 86400; done
fi
bashio::log.info "pgbackrest-cron: backup_enabled=true — entering schedule loop"

# Warn when no MQTT broker is configured. The sensors publish through the Supervisor
# mqtt/publish service proxy and silently no-op when MQTT is absent, so without this
# check users see no error — only missing entities. config.yaml declares 'mqtt:want'
# (soft dep) so bashio::services exposes availability without blocking startup.
if ! bashio::services.available "mqtt"; then
    bashio::log.warning "pgbackrest-cron: no MQTT service available — backup status sensors will not appear in Home Assistant. Install the Mosquitto broker app and enable the MQTT integration to publish sensors (backups themselves are unaffected)."
fi

# Pre-publish MQTT discovery config + last known state for all four backup sensors.
# WHY: entities are absent from HA until a message arrives on their discovery topic.
# Pre-publishing on startup shows real values immediately after a container restart.
bashio::log.info "pgbackrest-cron: pre-publishing MQTT discovery config for backup sensors"
for _pre_repo in 1 2; do
    _pre_info=$(env \
        "PGBACKREST_REPO1_CIPHER_PASS=$(cat "${SECRETS_DIR}/pgbackrest_cipher_pass_repo1" 2>/dev/null)" \
        "PGBACKREST_REPO2_CIPHER_PASS=$(cat "${SECRETS_DIR}/pgbackrest_cipher_pass_repo2" 2>/dev/null)" \
        gosu postgres /usr/bin/pgbackrest \
        --stanza=timescaledb "--repo=${_pre_repo}" \
        info --output=json 2>/dev/null || echo '[]')

    _pre_stop=$(printf '%s' "${_pre_info}" | jq -r \
        ".[0].backup | map(select(.database.\"repo-key\" == ${_pre_repo})) | last | .timestamp.stop // empty" \
        2>/dev/null || true)

    if [ -n "${_pre_stop:-}" ]; then
        _pre_ts=$(date -u -d "@${_pre_stop}" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "")
    else
        _pre_ts=""
    fi

    if [ -n "${_pre_ts:-}" ]; then
        update_ha_sensor "sensor.timescaledb_backup_last_backup_repo${_pre_repo}" "${_pre_ts}" '{}'
    else
        update_ha_sensor "sensor.timescaledb_backup_last_backup_repo${_pre_repo}" "unavailable" '{}'
    fi

    _pre_size=$(repo_du "${_pre_repo}")
    update_ha_sensor "sensor.timescaledb_backup_repo${_pre_repo}_size" "${_pre_size:-0}" '{}'
done

# ---------------------------------------------------------------------------
# run_backup <repo_id> <backup_type> [extra_pgbackrest_args...]
#
# Runs one pgbackrest backup operation with retry on transient failures.
# Retry loop: 6 iterations = 1 initial attempt (delay=0) + 5 retries.
# Delays: 0/60/120/300/600/900s  (D-03 / BKUP-07: 5-attempt with backoff).
# Max total wait before failure: 0+60+120+300+600+900 = 1980s (~33 min).
#
# On success: updates sensor.timescaledb_backup_last_backup_<repo_id> (ISO timestamp +
#   backup_type/duration attrs) and sensor.timescaledb_backup_<repo_id>_size (bytes).
# On failure: calls notify_backup_failure and logs an error; the caller continues.
#
# WHY gosu postgres: s6 run scripts execute as root; pgbackrest must run as the
# postgres OS user to access $PGDATA and UNIX socket (consistent with postgres/run).
#
# WHY $(cat ... 2>/dev/null) for cipher passphrases: reads secret from file at
# invocation time, scoping the value to the env of this one pgbackrest call only.
# The passphrase never appears in /proc/<pid>/cmdline (T-09-05). Pattern matches
# init-db.sh stanza-create block.
# ---------------------------------------------------------------------------
run_backup() {
    local repo_id="$1"
    local backup_type="$2"
    shift 2
    local extra_args=("$@")

    local _start
    _start=$(date +%s)
    local _stderr_file
    _stderr_file=$(mktemp)
    local _backup_ok=false
    local _attempt=0
    local _exit_code

    # for loop: 6 iterations = 1 initial attempt (delay=0) + 5 retries.
    # Delay 0 means no sleep before attempt 1; subsequent delays are 60/120/300/600/900s.
    # D-03 / BKUP-07: 5-attempt with backoff (counting from attempt 1, not attempt 0).
    for _delay in 0 60 120 300 600 900; do
        [ "${_delay}" -gt 0 ] && sleep "${_delay}"
        _attempt=$(( _attempt + 1 ))

        bashio::log.info "pgbackrest-cron: ${repo_id} ${backup_type} attempt ${_attempt}/6..."
        _exit_code=0
        # Capture stdout+stderr: pgbackrest writes its INFO and ERROR lines to
        # stdout via log-level-console=info, so a stderr-only redirect (the
        # previous behavior) left _stderr_file empty. That fed an empty string
        # into classify_pgbackrest_error and notify_backup_failure: the
        # classifier silently fell through to the default policy (regex never
        # matched anything) and the failure notification reached HA with
        # "Last error: " — no diagnostic context. Capturing combined output
        # makes both the regex match and the notification body meaningful.
        env \
            "PGBACKREST_REPO1_CIPHER_PASS=$(cat "${SECRETS_DIR}/pgbackrest_cipher_pass_repo1" 2>/dev/null)" \
            "PGBACKREST_REPO2_CIPHER_PASS=$(cat "${SECRETS_DIR}/pgbackrest_cipher_pass_repo2" 2>/dev/null)" \
            gosu postgres /usr/bin/pgbackrest \
            --stanza=timescaledb \
            "--repo=${repo_id##repo}" \
            --type="${backup_type}" \
            backup \
            "${extra_args[@]}" \
            >"${_stderr_file}" 2>&1 || _exit_code=$?

        # Forward the captured per-attempt output back to the cron log so the
        # addon log still shows pgbackrest's INFO/ERROR chatter. The combined
        # redirect above is required for classifier + notification correctness;
        # without this echo the redirect would also silently drop the per-attempt
        # progress lines that operators rely on to triage backup failures.
        cat "${_stderr_file}" || true

        if [ "${_exit_code}" -eq 0 ]; then
            _backup_ok=true
            break
        fi

        local _classification
        _classification=$(classify_pgbackrest_error "${_exit_code}" "${_stderr_file}")

        if [ "${_classification}" = "non-transient" ]; then
            bashio::log.error "pgbackrest-cron: ${repo_id} non-transient error (exit ${_exit_code}) — not retrying"
            break
        fi

        if [ "${_attempt}" -eq 6 ]; then
            bashio::log.error "pgbackrest-cron: ${repo_id} ${backup_type} retry exhaustion after ${_attempt} attempts (exit ${_exit_code})"
        else
            # WHY no "in Xs": _delay is the delay that just elapsed (consumed at the start
            # of this iteration by 'sleep "${_delay}"'), not the upcoming one. Reporting it
            # would mislead operators into thinking the next retry is immediate when it may
            # be up to 900s away. Use a neutral message rather than a wrong value.
            bashio::log.warning "pgbackrest-cron: ${repo_id} transient error (exit ${_exit_code}), attempt ${_attempt}/6 — retrying after backoff"
        fi
    done

    local _duration
    _duration=$(( $(date +%s) - _start ))

    if [ "${_backup_ok}" = "true" ]; then
        local _repo_key="${repo_id##repo}"

        local _ts
        _ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

        # Actual on-disk usage via SSH du (true folder total across all retained backups + WAL).
        # Falls back to 0 if SSH unavailable (openssh-client not installed or port 23 not enabled).
        local _size
        _size=$(repo_du "${_repo_key}")
        _size="${_size:-0}"

        local _attr_json
        _attr_json=$(jq -nc --arg t "${backup_type}" --argjson d "${_duration}" \
            '{"backup_type":$t,"duration_seconds":$d}')

        update_ha_sensor "sensor.timescaledb_backup_last_backup_${repo_id}" "${_ts}" "${_attr_json}"
        update_ha_sensor "sensor.timescaledb_backup_${repo_id}_size" "${_size}" '{}'

        bashio::log.info "pgbackrest-cron: ${repo_id} ${backup_type} backup complete (${_duration}s, ${_size} bytes on repo)"
    else
        local _stderr_tail
        _stderr_tail=$(tail -c 1024 "${_stderr_file}" 2>/dev/null || true)
        notify_backup_failure "${repo_id}" "${backup_type}" "${_stderr_tail}"
        bashio::log.error "pgbackrest-cron: ${repo_id} ${backup_type} backup failed after ${_attempt} attempt(s)"
    fi

    rm -f "${_stderr_file}"
}

# ---------------------------------------------------------------------------
# dispatch_for_date <date_str>
#
# date_str format: YYYY-MM-DD (from `date +"%Y-%m-%d"`)
#
# Repo1 calendar dispatch (BKUP-06):
#   1st Sunday of month → full backup then diff (the diff starts a chain so the
#     week's incrementals expire via retention-diff rather than living 3 years under
#     the full; this is not redundant — it is BKUP-06 design intent).
#   Other Sundays → diff
#   Mon–Sat → incr
#
# Repo2 annual dispatch (D-06):
#   Jan 1 → full backup taken inside a brief dual-archive window. PG's
#     archive-push fans WAL to repo1 + repo2 just long enough for pgbackrest
#     archive-check to pass and archive-copy=y to embed the start/stop WAL
#     into the repo2 backup directory. Steady state stays repo1-only. See
#     do_yearly_repo2_backup() below and plans/1-not-good-doesn-t-wondrous-robin.md
#     for the architectural rationale (the prior implementation used
#     --no-archive-check which produced apparently-complete but actually
#     non-self-contained backups).
#
# WHY _dow from `date +%u`: POSIX ISO 8601 — 1=Mon, 7=Sun. BusyBox date supports %u.
# WHY shell arithmetic for _first_sunday: _day -le 7 means today falls in the first
#   7-day window; combined with _dow=7 (Sunday) this is precisely the first Sunday.
# ---------------------------------------------------------------------------
dispatch_for_date() {
    local date_str="$1"
    local _year="${date_str:0:4}"
    local _month="${date_str:5:2}"
    local _day="${date_str:8:2}"
    local _dow
    _dow=$(date +%u)

    local _first_sunday=false
    [ "${_dow}" -eq 7 ] && [ "${_day}" -le 7 ] && _first_sunday=true

    # Repo1 calendar dispatch
    if [ "${_first_sunday}" = "true" ]; then
        bashio::log.info "pgbackrest-cron: first Sunday — dispatching repo1 full then diff"
        run_backup repo1 full
        # Diff after full creates the diff chain: weekly incrementals expire via retention-diff.
        # Not redundant — intentional per BKUP-06 design.
        run_backup repo1 diff
    elif [ "${_dow}" -eq 7 ]; then
        bashio::log.info "pgbackrest-cron: Sunday — dispatching repo1 diff"
        run_backup repo1 diff
    else
        bashio::log.info "pgbackrest-cron: weekday — dispatching repo1 incr"
        run_backup repo1 incr
    fi

    # Repo2 annual dispatch — Jan 1 only (independent of repo1 result)
    if [ "${_month}" = "01" ] && [ "${_day}" = "01" ]; then
        bashio::log.info "pgbackrest-cron: Jan 1 — dispatching repo2 annual full (dual-archive window)"
        do_yearly_repo2_backup
    fi

    # Phase 10 BKUP-15: weekly verify (Sundays, both repos sequentially).
    # WHY after the backup branches above:
    #   1. Running verify AFTER the day's backup means the freshest backup gets
    #      its integrity signal earliest. On the first Sunday of the month this
    #      naturally serializes full+diff → verify; on Jan 1 it serializes
    #      repo2 annual full → verify.
    #   2. Serialization via the single 02:00 wake-up is free — verify cannot
    #      overlap with the daily backup, which matters because both take the
    #      pgBackRest exclusive stanza lock. A second longrun would need
    #      explicit collision logic to achieve the same property (RESEARCH.md
    #      §D-08 option 1).
    #   3. '|| true' is deliberate: a verify failure already triggers its own HA
    #      notification via notify_verify_failure inside run-verify.sh; we must
    #      not skip the quarterly reminder branch below just because verify
    #      failed (RESEARCH.md open issue #2). Per-repo verify runs are also
    #      independent — a repo1 failure should not skip repo2.
    if [ "${_dow}" -eq 7 ]; then
        bashio::log.info "pgbackrest-cron: Sunday — dispatching weekly verify (repo1 then repo2)"
        /usr/lib/timescaledb/run-verify.sh repo1 || true
        /usr/lib/timescaledb/run-verify.sh repo2 || true
    fi

    # Phase 10 BKUP-16: quarterly drill reminder (Jan/Apr/Jul/Oct 1).
    # Unconditional — fires regardless of backup or verify outcome so the
    # operator is reminded to drill even when the day's backup itself failed
    # (RESEARCH.md open issue #2 final paragraph).
    case "${_month}" in
        01|04|07|10)
            if [ "${_day}" = "01" ]; then
                bashio::log.info "pgbackrest-cron: quarterly drill reminder — firing notifications"
                notify_quarterly_drill_due
            fi
            ;;
    esac
}

# ---------------------------------------------------------------------------
# do_yearly_repo2_backup — run the annual repo2 full so it is self-contained.
#
# Sequence:
#   1. enable_dual_archive  → swap archive_command config to fan WAL to both repos
#   2. force_wal_switch     → produce a fresh segment under the dual config
#   3. wait_for_wal_in_repo2 → confirm the segment landed in repo2's archive
#   4. run_backup repo2 full → archive-check passes, archive-copy=y embeds WAL
#   5. disable_dual_archive → swap back to repo1-only (always runs)
#   6. post_yearly_archive_cleanup → sftp rm the brief residual repo2 WAL
#
# WHY trap on EXIT of this function isn't enough: bash traps fire on shell exit,
# not function return. We use an explicit cleanup label + invoke disable on
# every exit path inside the function. The outer pgbackrest-cron loop must
# never get stuck with the dual config in place.
#
# Failures at any pre-backup step skip the backup and notify; this is preferred
# over running pgbackrest backup with the wrong archive config and producing
# yet another non-self-contained backup. The HA sensor for last_backup_repo2
# is updated by run_backup on success, so a skipped run is visible as a stale
# sensor timestamp.
# ---------------------------------------------------------------------------
do_yearly_repo2_backup() {
    if ! enable_dual_archive; then
        notify_supervisor "Yearly repo2 backup skipped" \
            "enable_dual_archive failed — check that pgbackrest-archive-dual.conf was rendered at startup. Restart the addon to retry." \
            "pgbackrest-yearly-repo2-skipped"
        return 1
    fi

    local _wal
    if ! _wal=$(force_wal_switch); then
        bashio::log.error "pgbackrest-cron: yearly repo2 abort — force_wal_switch failed"
        disable_dual_archive
        notify_supervisor "Yearly repo2 backup skipped" \
            "pg_switch_wal() failed before the annual repo2 backup. The addon is still healthy; investigate PostgreSQL connectivity." \
            "pgbackrest-yearly-repo2-skipped"
        return 1
    fi

    if ! wait_for_wal_in_repo2 "${_wal}" 120; then
        bashio::log.error "pgbackrest-cron: yearly repo2 abort — WAL ${_wal} not seen in repo2 archive within 120s"
        disable_dual_archive
        notify_supervisor "Yearly repo2 backup skipped" \
            "WAL segment ${_wal} did not appear in repo2 archive within 120s. The dual-archive window is broken; the annual backup did not run." \
            "pgbackrest-yearly-repo2-skipped"
        return 1
    fi

    # archive-check is now satisfied — drop the historical --no-archive-check.
    run_backup repo2 full

    disable_dual_archive
    post_yearly_archive_cleanup
    return 0
}

# ---------------------------------------------------------------------------
# Main loop: sleep until next 02:00 UTC, then dispatch.
#
# WHY POSIX arithmetic not 'date -d': Alpine BusyBox date does not support the
# -d 'tomorrow 02:00' syntax. Only $(date +%s) and shell arithmetic are used.
# _today_midnight = epoch of 00:00 UTC today (truncate seconds-since-epoch to full days).
# _target = _today_midnight + 7200 (7200s = 2h = 02:00 UTC).
# If 02:00 today already passed, advance _target by 86400s (one day).
# ---------------------------------------------------------------------------
# Manual trigger files for operator-driven runs (testing / retro-cleanup).
# Drop a file at one of these paths and pgbackrest-cron will execute the
# associated action on its next wake-up OR right away on service restart.
# Files are deleted once consumed so a single touch produces a single run.
FORCE_YEARLY_REPO2_TRIGGER=/data/force_yearly_repo2_backup

# On startup, consume any trigger files BEFORE entering the calendar sleep
# loop so an operator can: drop trigger -> restart addon -> immediate run.
if [ -f "${FORCE_YEARLY_REPO2_TRIGGER}" ]; then
    bashio::log.info "pgbackrest-cron: ${FORCE_YEARLY_REPO2_TRIGGER} found — running yearly repo2 backup now"
    rm -f "${FORCE_YEARLY_REPO2_TRIGGER}"
    do_yearly_repo2_backup || true
fi

while true; do
    _now=$(date +%s)
    _today_midnight=$(( _now - (_now % 86400) ))
    _target=$(( _today_midnight + 7200 ))  # 02:00 UTC = 2 * 3600 seconds past midnight
    [ "${_target}" -le "${_now}" ] && _target=$(( _target + 86400 ))
    _sleep=$(( _target - _now ))
    bashio::log.info "pgbackrest-cron: sleeping ${_sleep}s until next 02:00 UTC"
    sleep "${_sleep}"

    _today=$(date +"%Y-%m-%d")
    bashio::log.info "pgbackrest-cron: woke at 02:00 UTC for ${_today}"

    # Consume any operator trigger that arrived during the sleep window.
    if [ -f "${FORCE_YEARLY_REPO2_TRIGGER}" ]; then
        bashio::log.info "pgbackrest-cron: ${FORCE_YEARLY_REPO2_TRIGGER} found — running yearly repo2 backup ahead of calendar dispatch"
        rm -f "${FORCE_YEARLY_REPO2_TRIGGER}"
        do_yearly_repo2_backup || true
    fi

    dispatch_for_date "${_today}"
done
